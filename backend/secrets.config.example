# AWS Configuration for secrets.sh
# Copy this file to secrets.config and fill in your values
# Then source it: source secrets.config

# S3 Configuration
# Based on your S3 bucket: aws-s3-purchase-tracker-bucket
export S3_BUCKET=aws-s3-purchase-tracker-bucket
export S3_ENV_KEY=.env

# AWS Region (optional, defaults to us-east-2)
# export AWS_REGION=us-east-2

